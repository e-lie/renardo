{
  "name": "renardo-webclient-fresh",
  "version": "1.0.0a10",
  "type": "module",
  "private": true,
  "main": "electron/main.js",
  "description": "Renardo Web Client Fresh - Live coding with Python and SuperCollider",
  "homepage": "https://github.com/e-music-comp/renardo",
  "author": {
    "name": "Renardo Project",
    "email": "music.music@music.music"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 54321",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 54321",
    "start": "npm run dev",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "lint": "eslint .",
    "dev:electron": "concurrently \"npm run dev\" \"electron .\"",
    "build:electron": "vite build && electron-builder",
    "dist": "vite build && electron-builder --publish=never",
    "dist:appimage": "vite build && electron-builder --linux AppImage --publish=never"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@skeletonlabs/skeleton": "^4.8.0",
    "@skeletonlabs/skeleton-svelte": "^4.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tsconfig/svelte": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-svelte": "^2.35.1",
    "postcss": "^8.4.33",
    "prettier": "^3.2.4",
    "prettier-plugin-svelte": "^3.1.2",
    "svelte": "^5.40.1",
    "svelte-check": "^3.6.3",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "vitest": "^1.2.2"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/highlight": "^0.19.8",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.4",
    "@keenmate/svelte-treeview": "^4.4.0",
    "@lezer/highlight": "^1.2.3",
    "@replit/codemirror-vim": "^6.3.0",
    "@urql/core": "^4.0.15",
    "@urql/svelte": "^4.0.4",
    "graphql": "^16.8.1",
    "graphql-tag": "^2.12.6",
    "graphql-ws": "^5.14.2",
    "hydra-synth": "^1.4.0",
    "yaml": "^2.8.3"
  },
  "build": {
    "appId": "com.renardo.app",
    "productName": "Renardo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!python/**/*"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../src/renardo",
        "to": "renardo",
        "filter": [
          "**/*.py",
          "**/*.json",
          "**/*.yaml",
          "**/*.conf",
          "**/*.txt",
          "**/*.md",
          "**/*.toml"
        ]
      },
      {
        "from": "dist",
        "to": "renardo/webserver_fresh/static",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.music"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Audio",
      "maintainer": "Renardo Project <music.music@music.music>"
    },
    "win": {
      "target": "nsis"
    }
  }
}
